{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "http://schemas.dans.knaw.nl/ocfl/extensions/packaging-format-registry/config.schema.json",
  "title": "Packaging Format Registry config.json",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "extensionName": {
      "const": "packaging-format-registry"
    },
    "packagingFormatDigestAlgorithm": {
      "type": "string",
      "enum": ["md5", "sha1", "sha256", "sha512"]
    },
    "digestAlgorithm": {
      "type": "string",
      "enum": ["md5", "sha1", "sha256", "sha512"]
    }
  },
  "required": ["extensionName", "packagingFormatDigestAlgorithm", "digestAlgorithm"]
}
